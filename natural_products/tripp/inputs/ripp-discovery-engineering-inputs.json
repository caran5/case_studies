    "hites_strategy": {
      "method": "High-throughput elicitor screening",
      "workflow": [
        "Culture bacteria in 96-well plates with hundreds of elicitors",
        "Analyze using LAESI-IMS (laser ablation electrospray ionization mass spectrometry)",
        "Extract signals from each well",
        "Identify specific metabolite expression with particular elicitors",
        "Compare to other conditions",
        "Scale-up for isolation and characterization"
      ],
      "advantages": [
        "Rapid: 96-well plate analysis in <1 hour",
        "Applicable to rare actinomycetes",
        "Identifies cryptic metabolites"
      ],
      "example_discoveries": ["Clavorubin A (stimulated by actinomycin)", "Multiple sactipeptides"]
    }
  },

